        function validateGradesString(gradesStr) {
            if (!gradesStr || typeof gradesStr !== 'string') return false;
            const parts = gradesStr.split(',').map(s => s.trim()).filter(Boolean);
            if (parts.length === 0) return false;
            for (let p of parts) {
                const n = Number(p);
                if (!Number.isFinite(n) || n < 0 || n > 100) return false;
            }
            return true;
        }

        function validateGradesForm(form) {
            const gradesInput = form.querySelector('[name="grades"]');
            if (!gradesInput) return true; // nothing to validate
            const ok = validateGradesString(gradesInput.value);
            if (!ok) {
                alert('Grades must be comma-separated numbers between 0 and 100.');
                gradesInput.focus();
            }
            return ok;
        }

