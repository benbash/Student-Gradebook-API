<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Gradebook Dashboard</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="shell">
      <section class="hero">
        <div>
          <p class="eyebrow">EJS Frontend</p>
          <h1>Student Gradebook Dashboard</h1>
          <p class="lede">
            Create, update, delete, and review student results from one simple interface powered by
            the backend API.
          </p>
        </div>
        <div class="hero-actions">
          <a class="api-link secondary" href="/students" target="_blank" rel="noreferrer">View raw JSON</a>
          <button class="api-link" type="button" id="scroll-to-form">Add student</button>
        </div>
      </section>

      <section class="stats">
        <article class="stat-card">
          <span class="stat-label">Total students</span>
          <strong><%= stats.totalStudents %></strong>
        </article>
        <article class="stat-card">
          <span class="stat-label">Passing</span>
          <strong><%= stats.passCount %></strong>
        </article>
        <article class="stat-card">
          <span class="stat-label">Failing</span>
          <strong><%= stats.failCount %></strong>
        </article>
        <article class="stat-card">
          <span class="stat-label">Average of averages</span>
          <strong><%= stats.averageOfAverages %></strong>
        </article>
      </section>

      <section class="layout-grid">
        <section class="panel form-panel" id="student-form-panel">
          <div class="panel-head">
            <div>
              <p class="panel-kicker">Student form</p>
              <h2 id="form-title">Add student</h2>
            </div>
            <p>Last refreshed <%= lastUpdated %></p>
          </div>

          <form id="student-form" class="student-form">
            <input type="hidden" id="student-id" />

            <label class="field">
              <span>Name</span>
              <input type="text" id="student-name" name="name" placeholder="e.g. Ada Lovelace" required />
            </label>

            <label class="field">
              <span>Grades</span>
              <textarea
                id="student-grades"
                name="grades"
                rows="4"
                placeholder="Enter grades separated by commas, spaces, or new lines"
                required
              ></textarea>
            </label>

            <p class="field-hint">
              Example: <code>92, 85, 78</code> or one grade per line.
            </p>

            <div class="form-actions">
              <button type="submit" class="primary-btn" id="submit-btn">Create student</button>
              <button type="button" class="ghost-btn" id="cancel-edit" hidden>Cancel edit</button>
            </div>
            <p class="form-message" id="form-message" aria-live="polite"></p>
          </form>
        </section>

        <section class="panel">
          <div class="panel-head">
            <div>
              <p class="panel-kicker">Students</p>
              <h2>Records</h2>
            </div>
            <p><%= stats.totalStudents %> total entries</p>
          </div>

          <% if (typeof errorMessage !== "undefined") { %>
            <div class="empty-state error-state">
              <h3>Backend unavailable</h3>
              <p><%= errorMessage %></p>
            </div>
          <% } else if (!students.length) { %>
            <div class="empty-state">
              <h3>No students yet</h3>
              <p>Add a student from the form and the table will populate here.</p>
            </div>
          <% } else { %>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Grades</th>
                    <th>Average</th>
                    <th>High</th>
                    <th>Low</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% students.forEach((student) => { %>
                    <tr
                      data-student-row
                      data-id="<%= student.id %>"
                      data-name="<%= student.name %>"
                      data-grades="<%= student.grades.join(',') %>"
                    >
                      <td>
                        <div class="student-name"><%= student.name %></div>
                        <div class="student-id"><%= student.id %></div>
                      </td>
                      <td>
                        <div class="grades">
                          <% student.grades.forEach((grade) => { %>
                            <span class="grade-chip"><%= grade %></span>
                          <% }); %>
                        </div>
                      </td>
                      <td><%= student.average %></td>
                      <td><%= student.highest %></td>
                      <td><%= student.lowest %></td>
                      <td>
                        <span class="status <%= student.status === 'Pass' ? 'pass' : 'fail' %>">
                          <%= student.status %>
                        </span>
                      </td>
                      <td>
                        <div class="row-actions">
                          <button
                            type="button"
                            class="ghost-btn edit-btn"
                            data-action="edit"
                            data-id="<%= student.id %>"
                          >
                            Edit
                          </button>
                          <button
                            type="button"
                            class="danger-btn delete-btn"
                            data-action="delete"
                            data-id="<%= student.id %>"
                          >
                            Delete
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </section>
      </section>
    </main>

    <script src="/dashboard.js"></script>
  </body>
</html>
